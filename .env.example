# ================================
# MONVANA BANK - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ================================

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend (Settings → API Keys)
RESEND_API_KEY=your_resend_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Setup
ADMIN_SETUP_PASSWORD=your_super_secret_password_here
ADMIN_EMAIL=admin@monvana.online

# Admin PIN (required for sensitive admin actions like user suspension, balance edits)
ADMIN_PIN=your_admin_pin_here

# Smartsupp Live Chat Key
NEXT_PUBLIC_SMARTSUPP_KEY=your_smartsupp_key_here
